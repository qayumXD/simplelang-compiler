# SimpleLang Example: Variables and Types

func main() -> void:
    # Integer variables
    let x: int = 10
    let y: int = 20
    let sum = x + y
    
    # String variables
    let name: string = "Alice"
    let greeting = "Hello, " + name
    
    # Boolean variables
    let isActive: bool = true
    let isValid = x > 5
    
    # Float variables
    let price: float = 99.99
    let discount = price * 0.1
    
    # Print results
    print(sum)
    print(greeting)
    print(isActive)
    print(discount)
